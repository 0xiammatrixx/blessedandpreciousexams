# Generate this hash with: npm run hash:admin -- "your-strong-password"
ADMIN_PASSCODE_HASH=scrypt$16384$8$1$replace_salt$replace_digest
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority
MONGO_DB_NAME=blessedandpreciousexams
# Optional DNS override for environments where SRV lookups fail (example: 1.1.1.1,8.8.8.8)
MONGO_DNS_SERVERS=
DEFAULT_MAX_ATTEMPTS=3
# Optional: hide corrections/scores for this duration after submit (default 25 min = 1500000 ms)
# RESULT_RELEASE_DELAY_MS=1500000
VITE_API_BASE=https://your-backend-url.example.com
# Optional student idle auto-logout timeout (default 180000 ms = 3 minutes, non-exam screens).
# VITE_STUDENT_IDLE_TIMEOUT_MS=180000
KEEP_ALIVE_ENABLED=true
# Optional: set to your public backend URL for Render keep-alive.
# KEEP_ALIVE_URL=https://your-backend.onrender.com/api/keep-alive
# Optional override (default is 300000 ms = 5 minutes).
# KEEP_ALIVE_INTERVAL_MS=300000
