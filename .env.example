# Generate this hash with: npm run hash:admin -- "your-strong-password"
ADMIN_PASSCODE_HASH=scrypt$16384$8$1$replace_salt$replace_digest
KEEP_ALIVE_ENABLED=true
# Optional: set to your public backend URL for Render keep-alive.
# KEEP_ALIVE_URL=https://your-backend.onrender.com/api/keep-alive
# Optional override (default is 300000 ms = 5 minutes).
# KEEP_ALIVE_INTERVAL_MS=300000
